@using TCMine_Design

<!DOCTYPE html>
<html lang="pt">

<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <base href="/"/>
    <ResourcePreloader/>
    <style>@ColorTokens.ToCssBlockBoth()</style>
    <link rel="stylesheet" href="@Assets["_content/MudBlazor/MudBlazor.min.css"]"/>
    <link rel="stylesheet" href="@Assets["TCMine-Server.styles.css"]"/>
    <ImportMap/>
    <link rel="icon" type="image/png" href="favicon.png"/>
    <HeadOutlet @rendermode="@PageRenderMode"/>
    <title>TCMine Server</title>
</head>

<body>
<Routes @rendermode="@PageRenderMode"/>

<script src="@Assets["_framework/blazor.web.js"]"></script>
<script src="@Assets["_content/MudBlazor/MudBlazor.min.js"]"></script>
@* Editor Monaco (overrides) — loader + interop do BlazorMonaco (setup oficial de 3 scripts) *@
<script src="@Assets["_content/BlazorMonaco/jsInterop.js"]"></script>
<script src="@Assets["_content/BlazorMonaco/lib/monaco-editor/min/vs/loader.js"]"></script>
<script src="@Assets["_content/BlazorMonaco/lib/monaco-editor/min/vs/editor/editor.main.js"]"></script>
</body>

</html>

@code {
    [CascadingParameter] private HttpContext HttpContext { get; set; } = null!;

    // Render mode por requisição: interativo no geral, mas estático (null) nas páginas de auth
    // marcadas com [ExcludeFromInteractiveRouting] — elas precisam de SSR para emitir o cookie.
    private IComponentRenderMode? PageRenderMode =>
        HttpContext.AcceptsInteractiveRouting() ? InteractiveServer : null;

}

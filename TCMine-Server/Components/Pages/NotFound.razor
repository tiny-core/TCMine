@page "/not-found"
@page "/{**Slug:nonfile}"
@using TCMine_Server.Components.Shared
@layout MainLayout
@attribute [ExcludeFromInteractiveRouting]

<ErrorScreen Code="404"
             Title="Página não encontrada"
             Message="A página que você procura não existe ou foi movida."
             Icon="@Icons.Material.Filled.SearchOff"
             Color="Color.Primary">
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/"
               StartIcon="@Icons.Material.Filled.Home" Class="mt-2">
        Voltar para a Home
    </MudButton>
</ErrorScreen>

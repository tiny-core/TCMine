@page "/login"
@attribute [ExcludeFromInteractiveRouting]

@* Alias necessário — FluentValidation e MudBlazor ambos expõem um tipo "Severity" *@
@using Severity = MudBlazor.Severity

@* Página SSR estática (ver [ExcludeFromInteractiveRouting]): o submit é um POST real,
   o que permite emitir o cookie de autenticação via HttpContext.SignInAsync. O MudTextField
   funciona em SSR porque o name="Input.X" é splatado no <input> nativo (UserAttributes),
   permitindo o binding via [SupplyParameterFromForm]. *@
<MudGrid Justify="Justify.Center" Class="mt-8">
    <MudItem xs="12" sm="8" md="5" lg="4">

        <MudStack AlignItems="AlignItems.Center" Class="mb-6">
            <MudImage Src="images/logo.png" Width="80" Height="80"/>
            <MudText Typo="Typo.h5" Align="Align.Center">TCMine Server</MudText>
            <MudText Typo="Typo.body2" Align="Align.Center">Painel Administrativo</MudText>
        </MudStack>

        @if (_failed)
        {
            <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Outlined" Class="mb-4">
                Usuário ou senha inválidos.
            </MudAlert>
        }

        <MudPaper Class="pa-6" Elevation="0" Outlined="true">
            <EditForm Model="Input" method="post" OnValidSubmit="LoginUser" FormName="login">
                <DataAnnotationsValidator/>

                <MudStack Spacing="4">
                    <MudTextField T="string" @bind-Value="Input.Username" For="@(() => Input.Username)"
                                  name="Input.Username" Label="Usuário" Variant="Variant.Outlined"
                                  InputType="InputType.Text" Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Person" autocomplete="username"/>

                    <MudTextField T="string" @bind-Value="Input.Password" For="@(() => Input.Password)"
                                  name="Input.Password" Label="Senha" Variant="Variant.Outlined"
                                  InputType="InputType.Password" Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Lock" autocomplete="current-password"/>

                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
                               FullWidth="true" Size="Size.Large" Class="mt-2">
                        Entrar
                    </MudButton>
                </MudStack>
            </EditForm>
        </MudPaper>
    </MudItem>
</MudGrid>

@page "/admin"
@using TCMine_Server.Components.Pages.Admin.Dashboard.Widgets
@layout AdminLayout

@* Composição do dashboard a partir de widgets autocontidos. A página só carrega o agregado
   uma vez (OnInitializedAsync) e distribui aos widgets; o card de status do sistema gere o
   seu próprio timer/re-render, então as seções abaixo não re-renderizam de 2 em 2 segundos. *@

<DashboardHeader ServerVersion="@ServerVersion" EnvName="@EnvName" LauncherVersion="@LauncherVersion"/>

@* Aviso agregado: instâncias provisionadas cujo modpack mudou e precisam re-provisionar *@
@if (_data is { StaleInstances: > 0 })
{
    <MudAlert Severity="Severity.Warning" Class="mb-4" Icon="@Icons.Material.Filled.Sync">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudText>@_data.StaleInstances instância(s) desatualizada(s) — o modpack mudou desde a última provisão.</MudText>
            <MudButton Variant="Variant.Text" Color="Color.Inherit" Href="/admin/servers"
                       EndIcon="@Icons.Material.Filled.ArrowForward">
                Ver servidores
            </MudButton>
        </MudStack>
    </MudAlert>
}

<DashboardKpis Data="@_data"/>

<MudGrid Class="mb-4 mt-1">
    <MudItem xs="12" md="7">
        <SystemStatusCard/>
    </MudItem>
    <MudItem xs="12" md="5">
        <RecentActivityCard Activity="@(_data?.RecentActivity)"/>
    </MudItem>
</MudGrid>

@* Métricas ao vivo por instância de servidor (um card cada) — autocontido, gere o próprio timer *@
<ServerInstancesMetricsCard/>

<MudGrid Class="mb-4">
    <MudItem xs="12" md="7">
        <RecentModpacksCard Modpacks="@(_data?.RecentModpacks)"/>
    </MudItem>
    <MudItem xs="12" md="5">
        <ModDistributionCard Data="@_data"/>
    </MudItem>
</MudGrid>

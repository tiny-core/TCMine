@* Status do sistema: medidores de uso (CPU/RAM/disco) + métricas do processo + gráfico de memória.
   Componente AUTOCONTIDO — gere o seu próprio Timer e re-renderiza só a si mesmo a cada 2s,
   em vez de forçar o re-render da página inteira do dashboard. *@

<MudPaper Class="pa-4 mb-4" Elevation="0" Outlined="true">
    <MudText Typo="Typo.h6"
             Class="mb-2">Status do sistema
    </MudText>

    <MudDivider DividerType="DividerType.FullWidth"/>

    @* Medidores de uso GLOBAL do host/contêiner — anéis de progresso como referência visual.
       Rede não entra aqui (é taxa, não %): tem o seu próprio gráfico abaixo. *@
    <MudGrid Justify="Justify.Center" Class="my-4">
        <MudItem xs="6" md="4">
            @* CPU de todos os núcleos do host (não só do processo do servidor) *@
            <MetricGauge Value="@_snapshot.CpuPercent"
                         Label="CPU" Icon="@Icons.Material.Filled.Memory"
                         Caption="@($"host · {_snapshot.ProcessorCount} núcleos")"/>
        </MudItem>
        <MudItem xs="6" md="4">
            <MetricGauge Value="@_snapshot.RamPercent"
                         Label="RAM" Icon="@Icons.Material.Filled.DeveloperBoard"
                         Caption="@($"{_snapshot.RamUsedGb:0.0} / {_snapshot.RamTotalGb:0.0} GB")"/>
        </MudItem>
        <MudItem xs="6" md="4">
            @* Disco: uso total do drive que hospeda os dados do projeto *@
            <MetricGauge Value="@_snapshot.DiskPercent"
                         Label="Disco" Icon="@Icons.Material.Filled.Storage"
                         Caption="@($"{_snapshot.DiskUsedGb:0.0} / {_snapshot.DiskTotalGb:0} GB")"/>
        </MudItem>
    </MudGrid>

    <MudDivider DividerType="DividerType.FullWidth"/>

    @* Métricas do próprio processo do servidor — leitura secundária, em tiles compactos *@
    <MudGrid Spacing="2" Class="my-4">
        <MudItem xs="6" sm="3">
            <div class="metric-tile">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Processo</MudText>
                <MudText Typo="Typo.h6">@_snapshot.WorkingSetMb.ToString("0") <span class="metric-unit">MB</span>
                </MudText>
            </div>
        </MudItem>
        <MudItem xs="6" sm="3">
            <div class="metric-tile">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Heap (GC)</MudText>
                <MudText Typo="Typo.h6">@_snapshot.ManagedHeapMb.ToString("0") <span class="metric-unit">MB</span>
                </MudText>
            </div>
        </MudItem>
        <MudItem xs="6" sm="3">
            <div class="metric-tile">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Threads</MudText>
                <MudText Typo="Typo.h6">@_snapshot.Threads</MudText>
            </div>
        </MudItem>
        <MudItem xs="6" sm="3">
            <div class="metric-tile">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Uptime</MudText>
                <MudText Typo="Typo.h6">@Uptime</MudText>
            </div>
        </MudItem>
    </MudGrid>

</MudPaper>

@* Gráficos em papers próprios, lado a lado (empilham no mobile): memória (MB, absoluto) e rede
   (MB/s, taxa). Escalas diferentes → cada um no seu paper e eixo. Mesma amostragem (deste componente). *@
<MudGrid Class="mb-4" Spacing="4">
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="0" Outlined="true" Style="min-height: 425px;">
            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-2">
                <MudText Typo="Typo.h6">Memória do processo</MudText>
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Pico @PeakMemoryMb.ToString("0") MB</MudText>
            </MudStack>
            <MudDivider DividerType="DividerType.FullWidth"/>
            <MudChart T="double"
                      ChartType="ChartType.Line"
                      ChartSeries="@_memSeries"
                      ChartLabels="@_labels"
                      ChartOptions="@_memChartOptions"
                      Width="100%"/>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="0" Outlined="true" Style="min-height: 425px;">
            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-2">
                <MudText Typo="Typo.h6">Tráfego de rede</MudText>
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                    ↓ @FormatRate(_snapshot.Network.RecvBytesPerSec) · ↑ @FormatRate(_snapshot.Network.SentBytesPerSec)
                </MudText>
            </MudStack>
            <MudDivider DividerType="DividerType.FullWidth"/>
            <MudChart T="double"
                      ChartType="ChartType.Line"
                      ChartSeries="@_netSeries"
                      ChartLabels="@_labels"
                      ChartOptions="@_netChartOptions"
                      Width="100%"/>
        </MudPaper>
    </MudItem>
</MudGrid>

@* Status do sistema: medidores de uso (CPU/RAM/disco) + métricas do processo + gráfico de memória.
   Componente AUTOCONTIDO — gere o seu próprio Timer e re-renderiza só a si mesmo a cada 2s,
   em vez de forçar o re-render da página inteira do dashboard. *@

<MudPaper Class="pa-4 mud-height-full" Elevation="0" Outlined="true">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudText Typo="Typo.h6">Status do sistema</MudText>
        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.FiberManualRecord" Color="Color.Success" Size="Size.Small"/>
            <MudText Typo="Typo.caption" Color="Color.Secondary">Ao vivo</MudText>
        </MudStack>
    </MudStack>

    @* Medidores de uso GLOBAL do host/contêiner — anéis de progresso como referência visual *@
    <MudGrid Justify="Justify.Center" Class="mb-2">
        <MudItem xs="4">
            @* CPU de todos os núcleos do host (não só do processo do servidor) *@
            <MetricGauge Value="@_snapshot.CpuPercent"
                         Label="CPU" Icon="@Icons.Material.Filled.Memory"
                         Caption="@($"host · {_snapshot.ProcessorCount} núcleos")"/>
        </MudItem>
        <MudItem xs="4">
            <MetricGauge Value="@_snapshot.RamPercent"
                         Label="RAM" Icon="@Icons.Material.Filled.DeveloperBoard"
                         Caption="@($"{_snapshot.RamUsedGb:0.0} / {_snapshot.RamTotalGb:0.0} GB")"/>
        </MudItem>
        <MudItem xs="4">
            @* Disco: uso total do drive que hospeda os dados do projeto *@
            <MetricGauge Value="@_snapshot.DiskPercent"
                         Label="Disco" Icon="@Icons.Material.Filled.Storage"
                         Caption="@($"{_snapshot.DiskUsedGb:0.0} / {_snapshot.DiskTotalGb:0} GB")"/>
        </MudItem>
    </MudGrid>

    <MudDivider Class="my-3"/>

    @* Métricas do próprio processo do servidor — leitura secundária, em tiles compactos *@
    <MudGrid Spacing="2" Class="mb-4">
        <MudItem xs="6" sm="3">
            <div class="metric-tile">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Processo</MudText>
                <MudText Typo="Typo.h6">@_snapshot.WorkingSetMb.ToString("0") <span class="metric-unit">MB</span></MudText>
            </div>
        </MudItem>
        <MudItem xs="6" sm="3">
            <div class="metric-tile">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Heap (GC)</MudText>
                <MudText Typo="Typo.h6">@_snapshot.ManagedHeapMb.ToString("0") <span class="metric-unit">MB</span></MudText>
            </div>
        </MudItem>
        <MudItem xs="6" sm="3">
            <div class="metric-tile">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Threads</MudText>
                <MudText Typo="Typo.h6">@_snapshot.Threads</MudText>
            </div>
        </MudItem>
        <MudItem xs="6" sm="3">
            <div class="metric-tile">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Uptime</MudText>
                <MudText Typo="Typo.h6">@Uptime</MudText>
            </div>
        </MudItem>
    </MudGrid>

    <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-1">
        <MudText Typo="Typo.caption" Color="Color.Secondary">Uso de memória do processo (últimas amostras)</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary">Pico @PeakMemoryMb.ToString("0") MB</MudText>
    </MudStack>

    <MudChart T="double"
              ChartType="ChartType.Line"
              ChartSeries="@_series"
              ChartLabels="@_labels"
              ChartOptions="@_chartOptions"
              Width="100%" Height="220px"/>
</MudPaper>

@using TCMine_Domain.Modpack
@* Lista dos modpacks tocados mais recentemente. Recebe a lista (null = carregando). *@

<MudPaper Class="pa-4 mud-height-full" Elevation="0" Outlined="true">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
        <MudText Typo="Typo.h6">Modpacks recentes</MudText>
        <MudButton Href="/admin/modpacks" Variant="Variant.Text" Color="Color.Primary"
                   EndIcon="@Icons.Material.Filled.ArrowForward" Size="Size.Small">
            Ver todos
        </MudButton>
    </MudStack>

    @if (Modpacks is null)
    {
        @for (var i = 0; i < 4; i++)
        {
            <MudSkeleton Width="100%" Height="48px" Class="mb-2"/>
        }
    }
    else if (Modpacks.Count == 0)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-8">
            <MudIcon Icon="@Icons.Material.Filled.Inventory2" Color="Color.Secondary" Size="Size.Large"/>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Nenhum modpack cadastrado.</MudText>
        </MudStack>
    }
    else
    {
        <MudList T="string" Dense="true">
            @foreach (var m in Modpacks)
            {
                <MudListItem T="string" Href="@($"/admin/modpacks/{m.Id}")"
                             Icon="@Icons.Material.Filled.Inventory2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <div class="text-truncate">
                            <MudText Typo="Typo.body2">@m.Name</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                v@(m.Version) · @ModLoaders.DisplayName(m.Loader) · @m.ModCount mods
                            </MudText>
                        </div>
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            @if (!string.IsNullOrWhiteSpace(m.CurseForgeUrl))
                            {
                                <MudChip T="string" Href="@m.CurseForgeUrl" Target="_blank" Size="Size.Small"
                                         Variant="Variant.Filled" Icon="@Icons.Material.Filled.OpenInNew"
                                         Style="background:#F16436;color:#fff;">CurseForge
                                </MudChip>
                            }
                            @if (m.IsPublished)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">
                                    Publicado
                                </MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                                    Rascunho
                                </MudChip>
                            }
                            <MudText Typo="Typo.caption"
                                     Color="Color.Secondary">@RelativeTime.Format(m.UpdatedAt)</MudText>
                        </MudStack>
                    </MudStack>
                </MudListItem>
            }
        </MudList>
    }
</MudPaper>

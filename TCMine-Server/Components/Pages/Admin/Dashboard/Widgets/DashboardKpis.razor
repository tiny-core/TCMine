@* Grade de KPIs do dashboard. Recebe o agregado (null = ainda carregando → mostra "—"). *@

<MudGrid Spacing="4" Class="mb-4">
    <MudItem xs="12" sm="6" md="4" lg="3">
        <StatCard Icon="@Icons.Material.Filled.Inventory2"
                  Color="Color.Primary"
                  Title="Modpacks"
                  Value="@(Data?.Modpacks.ToString() ?? "—")">
            <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Public">
                @(Data is null ? null : $"{Data.PublishedModpacks} Publicados")
            </MudChip>
        </StatCard>
    </MudItem>
    <MudItem xs="12" sm="6" md="4" lg="3">
        <StatCard Icon="@Icons.Material.Filled.Extension"
                  Color="Color.Info"
                  Title="Mods"
                  Value="@(Data?.Mods.ToString() ?? "—")">
            @if (Data is not null)
            {
                <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Dns">
                    @Data.ServerMods Servidor
                </MudChip>
                <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.DataUsage">
                    @Data.SharedMods
                </MudChip>
                <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Computer">
                    @Data.ClientMods Cliente
                </MudChip>
            }
        </StatCard>
    </MudItem>
    <MudItem xs="12" sm="6" md="4" lg="3">
        <StatCard Icon="@Icons.Material.Filled.Dns"
                  Color="Color.Success"
                  Title="Instâncias"
                  Value="@(Data?.Instances.ToString() ?? "—")">
            <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.PlayArrow">
                @(Data is null ? null : $"{Data.RunningInstances} Rodando")</MudChip>
        </StatCard>
    </MudItem>
    <MudItem xs="12" sm="6" md="4" lg="3">
        <StatCard Icon="@Icons.Material.Filled.CloudUpload"
                  Color="Color.Warning"
                  Title="Releases"
                  Value="@(Data?.Releases.ToString() ?? "—")">
            <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Update">
                @(Data?.LatestReleaseVersion is { } v ? $"última v{v}" : "Nenhuma")
            </MudChip>
        </StatCard>
    </MudItem>
    <MudItem xs="12" sm="6" md="4" lg="3">
        <StatCard Icon="@Icons.Material.Filled.Public"
                  Color="Color.Tertiary"
                  Title="Servidores"
                  Value="@(Data?.Servers.ToString() ?? "—")">
        </StatCard>
    </MudItem>
    <MudItem xs="12" sm="6" md="4" lg="3">
        <StatCard Icon="@Icons.Material.Filled.Public"
                  Color="Color.Warning"
                  Title="Novidades globais"
                  Value="@(Data?.GlobalNews.ToString() ?? "—")">
        </StatCard>
    </MudItem>
    <MudItem xs="12" sm="6" md="4" lg="3">
        <StatCard Icon="@Icons.Material.Filled.Newspaper"
                  Color="Color.Warning"
                  Title="Novidades de modpacks"
                  Value="@(Data?.ModpackNews.ToString() ?? "—")">
        </StatCard>
    </MudItem>
    <MudItem xs="12" sm="6" md="4" lg="3">
        <StatCard Icon="@Icons.Material.Filled.People"
                  Color="Color.Secondary"
                  Title="Usuários"
                  Value="@(Data?.Users.ToString() ?? "—")">

        </StatCard>
    </MudItem>
</MudGrid>
@using TCMine_Domain.Identity

@* Formulário de criar/editar um usuário do painel. Devolve um UserFormResult; a persistência
   (hash, unicidade do login, proteção do último Owner) fica com o UserService, chamado pela página.
   Na criação a senha é obrigatória; na edição é opcional (preencher = redefinir). *@

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form">
            <MudTextField @bind-Value="_username" Label="Login" Variant="Variant.Outlined"
                          Required="true" RequiredError="O login é necessário"
                          MaxLength="60" Immediate="true"
                          HelperText="Usado para entrar — normalizado para minúsculas."/>

            <MudSelect @bind-Value="_role" Label="Papel" Variant="Variant.Outlined" Class="mt-4">
                @foreach (var role in Enum.GetValues<UserRole>())
                {
                    <MudSelectItem Value="role">@RoleLabel(role)</MudSelectItem>
                }
            </MudSelect>

            <MudTextField @bind-Value="_password" Label="@(IsEdit ? "Nova senha (opcional)" : "Senha")"
                          Variant="Variant.Outlined" Class="mt-4"
                          InputType="InputType.Password" MaxLength="200"
                          Required="@(!IsEdit)" RequiredError="A senha é necessária"
                          Validation="@(new Func<string, string?>(ValidatePassword))"
                          HelperText="@(IsEdit ? "Deixe em branco para manter a senha atual." : "Mínimo de 8 caracteres.")"/>

            <MudTextField @bind-Value="_confirm" Label="Confirmar senha" Variant="Variant.Outlined" Class="mt-4"
                          InputType="InputType.Password" MaxLength="200"
                          Validation="@(new Func<string, string?>(ValidateConfirm))"/>

            @if (IsEdit)
            {
                <MudSwitch T="bool" @bind-Value="_isActive" Color="Color.Success" Class="mt-4"
                           Label="Ativo (conta inativa não consegue entrar)"/>
            }
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Confirm">
            @(IsEdit ? "Salvar" : "Criar")
        </MudButton>
    </DialogActions>
</MudDialog>

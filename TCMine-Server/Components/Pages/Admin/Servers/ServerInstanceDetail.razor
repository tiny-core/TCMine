@page "/admin/servers/{Id:guid}"
@layout AdminLayout
@attribute [Authorize(Roles = "Owner,Admin,Operator")]
@using Microsoft.AspNetCore.Authorization
@using TCMine_Domain.Entities
@using TCMine_Server.Infrastructure.ServerInstances

@* Detalhe de uma instância: status + ações de ciclo de vida, console ao vivo (logs do container +
   envio de comandos) e edição dos arquivos de config (server.properties, whitelist, ops, banlists). *@

@if (_detail is null)
{
    @* BusyOverlay cobre o carregamento inicial *@
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo("/admin/servers"))"/>
            <div>
                <MudText Typo="Typo.h4">@_detail.Edit.Name</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    @_detail.ModpackName · porta @_detail.Edit.Port
                </MudText>
            </div>
            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@StatusColor(_detail.Status)">
                @StatusLabel(_detail.Status)
            </MudChip>
            @if (_detail.Status is ServerInstanceStatus.Running)
            {
                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Info"
                         Icon="@Icons.Material.Filled.People">
                    @(_ping is not null ? $"{_ping.Online}/{_ping.Max} jogadores" : "consultando…")
                </MudChip>
            }
        </MudStack>

        <MudStack Row="true" Spacing="1">
            @if (_detail.Provisioned && _detail.IsStale)
            {
                <MudButton StartIcon="@Icons.Material.Filled.SystemUpdateAlt" Color="Color.Warning"
                           Variant="Variant.Filled" Disabled="@IsProvisioning" OnClick="StartProvision">
                    Aplicar atualização
                </MudButton>
            }
            else
            {
                <MudButton StartIcon="@Icons.Material.Filled.Build" Variant="Variant.Outlined"
                           Disabled="@IsProvisioning" OnClick="StartProvision">
                    Provisionar
                </MudButton>
            }
            @if (_detail.Status is ServerInstanceStatus.Running or ServerInstanceStatus.Starting)
            {
                <MudButton StartIcon="@Icons.Material.Filled.Stop" Color="Color.Warning" Variant="Variant.Filled"
                           OnClick="StopAsync">Parar
                </MudButton>
            }
            else
            {
                <MudButton StartIcon="@Icons.Material.Filled.PlayArrow" Color="Color.Success" Variant="Variant.Filled"
                           Disabled="@(!_detail.Provisioned || IsProvisioning)" OnClick="StartAsync">Iniciar
                </MudButton>
            }
            @if (_detail.Provisioned)
            {
                <MudButton StartIcon="@Icons.Material.Filled.Tune" Variant="Variant.Outlined"
                           Href="@($"/admin/servers/{Id}/config")">Configurações</MudButton>
            }
            <MudButton StartIcon="@Icons.Material.Filled.Edit" OnClick="EditAsync" Variant="Variant.Outlined">
                Editar
            </MudButton>
        </MudStack>
    </MudStack>

    @if (!_detail.Provisioned)
    {
        <MudAlert Severity="Severity.Warning" Class="mb-4" Dense="true">
            Instância ainda não provisionada — clique em <b>Provisionar</b> para montar o diretório (loader, mods, configs).
        </MudAlert>
    }
    else if (_detail.IsStale)
    {
        <MudAlert Severity="Severity.Warning" Class="mb-4" Dense="true">
            O modpack mudou desde a última provisão — clique em <b>Aplicar atualização</b> para re-montar os mods/configs.
            @if (_detail.Status is ServerInstanceStatus.Running)
            {
                <span> Reinicie o servidor depois para os mods novos valerem.</span>
            }
        </MudAlert>
    }

    @* ── Progresso do provisionamento (via coordenador; reconecta após refresh) ─────────────────── *@
    @if (_job is not null)
    {
        <MudPaper Elevation="0" Outlined="true" Class="pa-4 mb-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="mb-3">
                @if (_job.State == ProvisionState.Running)
                {
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Medium"/>
                }
                else if (_job.State == ProvisionState.Succeeded)
                {
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Large"/>
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Large"/>
                }
                <div class="flex-grow-1">
                    <MudText Typo="Typo.h6">
                        @(_job.State switch
                        {
                            ProvisionState.Running => JobGlobalStatus,
                            ProvisionState.Succeeded => "Provisionamento concluído",
                            _ => "Falha no provisionamento"
                        })
                    </MudText>
                    @if (_job.State == ProvisionState.Failed && _job.Error is not null)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Error">@_job.Error</MudText>
                    }
                </div>
                @if (_job.State != ProvisionState.Running)
                {
                    <MudButton Variant="Variant.Text" OnClick="DismissJob">Fechar</MudButton>
                }
            </MudStack>

            @if (_job.Steps.Count > 0)
            {
                <div class="provision-steps" @ref="_jobStepsEl">
                    @{
                        var steps = _job.Steps;
                        var lastIndex = steps.Count - 1;
                    }
                    @for (var i = 0; i < steps.Count; i++)
                    {
                        var step = steps[i];
                        var isCurrent = _job.State == ProvisionState.Running && i == lastIndex;
                        <div class="provision-step">
                            @if (isCurrent)
                            {
                                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small"/>
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small"/>
                            }
                            <span class="provision-step-text @(isCurrent ? "provision-step-text--current" : null)">@step</span>
                        </div>
                    }
                </div>
            }
        </MudPaper>
    }

    @* ── Console ao vivo (log + comandos) ───────────────────────────────────────────────────────── *@
    <MudPaper Elevation="0" Outlined="true" Class="pa-4">
        @if (_detail.ContainerId is not null)
        {
            @if (_detail.Status is ServerInstanceStatus.Crashed)
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mb-3" Icon="@Icons.Material.Filled.Error">
                    O servidor caiu. O log da última execução está abaixo — procure o erro perto do fim.
                </MudAlert>
            }
            else if (_detail.Status is not ServerInstanceStatus.Running)
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                    Servidor parado — exibindo o log da última execução.
                </MudAlert>
            }

            <div class="server-console">
                <pre class="server-console__log">@_log</pre>
            </div>

            @if (_detail.Status is ServerInstanceStatus.Running)
            {
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-3">
                    <MudTextField @bind-Value="_command" Placeholder="Comando do servidor (ex.: say olá, op nick)…"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true"
                                  OnKeyDown="OnCommandKeyDown" Class="flex-grow-1"/>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" EndIcon="@Icons.Material.Filled.Send"
                               OnClick="SendCommandAsync">Enviar
                    </MudButton>
                </MudStack>
            }
        }
        else
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-12">
                <MudIcon Icon="@Icons.Material.Filled.Terminal" Color="Color.Secondary" Size="Size.Large"/>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    O console aparece após iniciar o servidor (e mantém o log da última execução para diagnóstico).
                    As configurações ficam no botão <b>Configurações</b> acima.
                </MudText>
            </MudStack>
        }
    </MudPaper>
}

<style>
    .server-console__log {
        background: var(--mud-palette-dark, #1e1e1e);
        color: #d4d4d4;
        font-family: 'Cascadia Code', Consolas, monospace;
        font-size: 12px;
        line-height: 1.5;
        padding: 12px;
        border-radius: 6px;
        height: 52vh;
        overflow-y: auto;
        white-space: pre-wrap;
        word-break: break-all;
        margin: 0;
    }

    .server-config-editor textarea {
        font-family: 'Cascadia Code', Consolas, monospace;
        font-size: 13px;
    }

    /* Log de passos do provisionamento — altura limitada + scroll (auto-scroll no code-behind) */
    .provision-steps {
        max-height: 200px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 6px;
        padding: 12px;
        border-radius: 8px;
        background: var(--mud-palette-background-grey);
        border: 1px solid var(--mud-palette-lines-default);
    }

    .provision-step {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        font-size: 0.8rem;
        line-height: 1.35;
    }

    .provision-step > :first-child {
        flex: 0 0 auto;
        margin-top: 1px;
    }

    .provision-step-text {
        color: var(--mud-palette-text-secondary);
        overflow-wrap: anywhere;
    }

    .provision-step-text--current {
        color: var(--mud-palette-text-primary);
        font-weight: 500;
    }
</style>

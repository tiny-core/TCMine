@page "/admin/servers/{Id:guid}"
@layout AdminLayout
@attribute [Authorize(Roles = "Owner,Admin,Operator")]
@using Microsoft.AspNetCore.Authorization
@using TCMine_Domain.Entities

@* Detalhe de uma instância: status + ações de ciclo de vida, console ao vivo (logs do container +
   envio de comandos) e edição dos arquivos de config (server.properties, whitelist, ops, banlists). *@

@if (_detail is null)
{
    @* BusyOverlay cobre o carregamento inicial *@
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo("/admin/servers"))"/>
            <div>
                <MudText Typo="Typo.h4">@_detail.Edit.Name</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    @_detail.ModpackName · porta @_detail.Edit.Port
                </MudText>
            </div>
            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@StatusColor(_detail.Status)">
                @StatusLabel(_detail.Status)
            </MudChip>
            @if (_detail.Status is ServerInstanceStatus.Running)
            {
                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Info"
                         Icon="@Icons.Material.Filled.People">
                    @(_ping is not null ? $"{_ping.Online}/{_ping.Max} jogadores" : "consultando…")
                </MudChip>
            }
        </MudStack>

        <MudStack Row="true" Spacing="1">
            @if (_detail.Provisioned && _detail.IsStale)
            {
                <MudButton StartIcon="@Icons.Material.Filled.SystemUpdateAlt" Color="Color.Warning"
                           Variant="Variant.Filled" OnClick="ProvisionAsync">Aplicar atualização</MudButton>
            }
            else
            {
                <MudButton StartIcon="@Icons.Material.Filled.Build" OnClick="ProvisionAsync" Variant="Variant.Outlined">
                    Provisionar
                </MudButton>
            }
            @if (_detail.Status is ServerInstanceStatus.Running or ServerInstanceStatus.Starting)
            {
                <MudButton StartIcon="@Icons.Material.Filled.Stop" Color="Color.Warning" Variant="Variant.Filled"
                           OnClick="StopAsync">Parar
                </MudButton>
            }
            else
            {
                <MudButton StartIcon="@Icons.Material.Filled.PlayArrow" Color="Color.Success" Variant="Variant.Filled"
                           Disabled="@(!_detail.Provisioned)" OnClick="StartAsync">Iniciar
                </MudButton>
            }
            <MudButton StartIcon="@Icons.Material.Filled.Edit" OnClick="EditAsync" Variant="Variant.Outlined">
                Editar
            </MudButton>
        </MudStack>
    </MudStack>

    @if (!_detail.Provisioned)
    {
        <MudAlert Severity="Severity.Warning" Class="mb-4" Dense="true">
            Instância ainda não provisionada — clique em <b>Provisionar</b> para montar o diretório (loader, mods, configs).
        </MudAlert>
    }
    else if (_detail.IsStale)
    {
        <MudAlert Severity="Severity.Warning" Class="mb-4" Dense="true">
            O modpack mudou desde a última provisão — clique em <b>Aplicar atualização</b> para re-montar os mods/configs.
            @if (_detail.Status is ServerInstanceStatus.Running)
            {
                <span> Reinicie o servidor depois para os mods novos valerem.</span>
            }
        </MudAlert>
    }

    <MudTabs Elevation="0" Outlined="true" ApplyEffectsToContainer="true">
        @* ── Console ao vivo ────────────────────────────────────────────────────────────────────── *@
        <MudTabPanel Text="Console" Icon="@Icons.Material.Filled.Terminal">
            @if (_detail.Status is ServerInstanceStatus.Running && _detail.ContainerId is not null)
            {
                <div class="server-console">
                    <pre class="server-console__log">@_log</pre>
                </div>
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-3">
                    <MudTextField @bind-Value="_command" Placeholder="Comando do servidor (ex.: say olá, op nick)…"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true"
                                  OnKeyDown="OnCommandKeyDown" Class="flex-grow-1"/>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" EndIcon="@Icons.Material.Filled.Send"
                               OnClick="SendCommandAsync">Enviar
                    </MudButton>
                </MudStack>
            }
            else
            {
                <MudStack AlignItems="AlignItems.Center" Class="py-12">
                    <MudIcon Icon="@Icons.Material.Filled.Terminal" Color="Color.Secondary" Size="Size.Large"/>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        O console fica disponível com o servidor em execução.
                    </MudText>
                </MudStack>
            }
        </MudTabPanel>

        @* ── Configurações (arquivos editáveis) ─────────────────────────────────────────────────── *@
        <MudTabPanel Text="Configurações" Icon="@Icons.Material.Filled.Tune">
            @if (_editableFiles.Count == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Provisione a instância para gerar os arquivos de configuração editáveis.
                </MudText>
            }
            else
            {
                <MudStack Row="true" Spacing="4" AlignItems="AlignItems.Center" Class="mb-3">
                    <MudSelect T="string" Value="_selectedFile" ValueChanged="OnFileSelected" Label="Arquivo"
                               Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width:320px">
                        @foreach (var f in _editableFiles)
                        {
                            <MudSelectItem Value="f">@f</MudSelectItem>
                        }
                    </MudSelect>
                    <MudSpacer/>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save"
                               Disabled="@string.IsNullOrEmpty(_selectedFile)" OnClick="SaveFileAsync">Salvar
                    </MudButton>
                </MudStack>
                <MudTextField @bind-Value="_fileContent" Variant="Variant.Outlined" Lines="20"
                              Class="server-config-editor" Immediate="true"
                              HelperText="Mudanças só valem após reiniciar o servidor (ou recarregar a config in-game)."/>
            }
        </MudTabPanel>
    </MudTabs>
}

<style>
    .server-console__log {
        background: var(--mud-palette-dark, #1e1e1e);
        color: #d4d4d4;
        font-family: 'Cascadia Code', Consolas, monospace;
        font-size: 12px;
        line-height: 1.5;
        padding: 12px;
        border-radius: 6px;
        height: 52vh;
        overflow-y: auto;
        white-space: pre-wrap;
        word-break: break-all;
        margin: 0;
    }

    .server-config-editor textarea {
        font-family: 'Cascadia Code', Consolas, monospace;
        font-size: 13px;
    }
</style>

@page "/admin/servers"
@layout AdminLayout
@attribute [Authorize(Roles = "Owner,Admin,Operator")]
@using Microsoft.AspNetCore.Authorization
@using TCMine_Application.Contracts
@using TCMine_Domain.Entities

@* Instâncias de servidor Minecraft derivadas dos modpacks. Cada linha mostra o status de runtime e
   dá as ações de ciclo de vida (provisionar, iniciar, parar) + acesso ao detalhe/console. *@

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-6">
    <div>
        <MudText Typo="Typo.h4">Servidores</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary">
            Instâncias de servidor Minecraft, derivadas dos modpacks e executadas em containers.
        </MudText>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
               OnClick="CreateAsync">Nova instância
    </MudButton>
</MudStack>

<MudPaper Elevation="0" Outlined="true">
    @* Durante o carregamento o BusyOverlay global cobre a tela; aqui não renderizamos nada. *@
    @if (_rows is null)
    {
    }
    else if (_rows.Count == 0)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-12">
            <MudIcon Icon="@Icons.Material.Filled.Dns" Color="Color.Secondary" Size="Size.Large"/>
            <MudText Typo="Typo.h6">Nenhuma instância ainda</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Crie uma instância a partir de um modpack para começar.
            </MudText>
        </MudStack>
    }
    else
    {
        <MudDataGrid T="ServerInstanceRowDto" Items="_rows" Hover="true" Dense="true" Elevation="0"
                     FixedHeader="true" Height="68vh" Filterable="false" QuickFilter="Filter"
                     RowsPerPage="25">
            <ToolBarContent>
                <MudTextField @bind-Value="_search" Placeholder="Filtrar por nome ou modpack…"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true" Clearable="true" Class="mt-0" Margin="Margin.Dense"/>
            </ToolBarContent>
            <Columns>
                <TemplateColumn Title="Nome" Sortable="true" SortBy="x => x.Name">
                    <CellTemplate>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Dns" Size="Size.Small" Color="Color.Primary"/>
                            <div>
                                <MudText Typo="Typo.body2">@context.Item.Name</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Item.ModpackName</MudText>
                            </div>
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Status" Sortable="true" SortBy="x => x.Status">
                    <CellTemplate>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                                 Color="@StatusColor(context.Item.Status)"
                                 Icon="@StatusIcon(context.Item.Status)">@StatusLabel(context.Item.Status)
                        </MudChip>
                        @if (!context.Item.Provisioned)
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning"
                                     Icon="@Icons.Material.Filled.Build">Não provisionada
                            </MudChip>
                        }
                        else if (context.Item.IsStale)
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning"
                                     Icon="@Icons.Material.Filled.Sync">Desatualizada
                            </MudChip>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.Port" Title="Porta"/>
                <TemplateColumn Title="Jogadores" Sortable="false">
                    <CellTemplate>
                        @if (context.Item.Status is ServerInstanceStatus.Running)
                        {
                            @if (_pings.TryGetValue(context.Item.Id, out var ping) && ping is not null)
                            {
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Small" Color="Color.Info"/>
                                    <MudText Typo="Typo.body2">@ping.Online/@ping.Max</MudText>
                                </MudStack>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">…</MudText>
                            }
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">—</MudText>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="RAM" Sortable="true" SortBy="x => x.RamMb">
                    <CellTemplate>@($"{context.Item.RamMb / 1024.0:0.#} GB")</CellTemplate>
                </TemplateColumn>
                <TemplateColumn Sortable="false" CellStyle="text-align:right">
                    <CellTemplate>
                        <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd">
                            @* Parar (se rodando) e abrir o detalhe. Iniciar/provisionar/apagar vivem no
                               detalhe e no hub do modpack — a lista é para visão geral. *@
                            @if (context.Item.Status is ServerInstanceStatus.Running or ServerInstanceStatus.Starting)
                            {
                                <MudTooltip Text="Parar">
                                    <MudIconButton Icon="@Icons.Material.Filled.Stop" Size="Size.Small" Color="Color.Warning"
                                                   OnClick="@(() => StopAsync(context.Item))"/>
                                </MudTooltip>
                            }
                            <MudTooltip Text="Detalhe e console">
                                <MudIconButton Icon="@Icons.Material.Filled.Terminal" Size="Size.Small" Color="Color.Primary"
                                               OnClick="@(() => Open(context.Item))"/>
                            </MudTooltip>
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
            <PagerContent>
                <MudDataGridPager T="ServerInstanceRowDto" PageSizeOptions="new[] { 25, 50, 100 }"/>
            </PagerContent>
        </MudDataGrid>
    }
</MudPaper>

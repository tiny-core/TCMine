@page "/admin/modpacks"
@layout AdminLayout
@attribute [Authorize(Roles = "Owner,Admin")]
@using Microsoft.AspNetCore.Authorization
@using TCMine_Application.Contracts
@using TCMine_Domain.Modpack

@* Catálogo de modpacks em tabela (mesmo padrão da página de Mods): MudDataGrid com busca + pager,
   só as colunas relevantes. Toda a edição vive no ModpackEditor — esta página lista, cria e apaga. *@

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-6" Wrap="Wrap.Wrap">
    <div>
        <MudText Typo="Typo.h4">Modpacks</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary">
            Crie e gerencie os modpacks oficiais — mods, overrides e servidores.
        </MudText>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add" Href="/admin/modpacks/new">
        Novo modpack
    </MudButton>
</MudStack>

@if (!_cfConfigured)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
        O token do CurseForge não está configurado — a busca e o import de modpacks ficarão indisponíveis.
        <MudLink Href="/admin/settings" Class="ml-1">Configurar</MudLink>
    </MudAlert>
}

<MudPaper Elevation="0" Outlined="true">
    @* Durante o carregamento o BusyOverlay global cobre a tela; aqui não renderizamos nada. *@
    @if (_rows is null)
    {
    }
    else if (_rows.Count == 0)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-12">
            <MudIcon Icon="@Icons.Material.Filled.Inventory2" Color="Color.Secondary" Size="Size.Large"/>
            <MudText Typo="Typo.h6">Nenhum modpack ainda</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">Crie o primeiro modpack para começar.</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add" Href="/admin/modpacks/new">
                Novo modpack
            </MudButton>
        </MudStack>
    }
    else
    {
        <MudDataGrid T="ModpackAdminRowDto" Items="_rows" Hover="true" Dense="true" Elevation="0"
                     FixedHeader="true" Height="68vh" Filterable="false" QuickFilter="Filter"
                     RowsPerPage="25">
            <ToolBarContent>
                <MudTextField @bind-Value="_search" Placeholder="Filtrar por nome ou Minecraft…"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true" Clearable="true" Class="mt-0" Margin="Margin.Dense"/>
            </ToolBarContent>
            <Columns>
                <TemplateColumn Title="Nome" Sortable="true" SortBy="x => x.Name">
                    <CellTemplate>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Small" Color="Color.Primary"/>
                            <div>
                                <MudText Typo="Typo.body2">@context.Item.Name</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">v@(context.Item.Version)</MudText>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(context.Item.CurseForgeUrl))
                            {
                                <MudLink Href="@context.Item.CurseForgeUrl" Target="_blank" Underline="Underline.None">
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                             Icon="@Icons.Material.Filled.OpenInNew"
                                             Style="background:#F16436;color:#fff;">CurseForge</MudChip>
                                </MudLink>
                            }
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.Minecraft" Title="Minecraft"/>
                <TemplateColumn Title="Loader" Sortable="true" SortBy="x => x.Loader">
                    <CellTemplate>@ModLoaders.DisplayName(context.Item.Loader) @context.Item.LoaderVersion</CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.ModCount" Title="Mods" CellStyle="text-align:center"/>
                <TemplateColumn Title="Status" Sortable="true" SortBy="x => x.IsPublished" CellStyle="text-align:center">
                    <CellTemplate>
                        @if (context.Item.IsPublished)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">Publicado</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Rascunho</MudChip>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Atualizado" Sortable="true" SortBy="x => x.UpdatedAt">
                    <CellTemplate>@RelativeTime.Format(context.Item.UpdatedAt)</CellTemplate>
                </TemplateColumn>
                <TemplateColumn Sortable="false" CellStyle="text-align:right">
                    <CellTemplate>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       OnClick="@(() => Edit(context.Item))"/>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                       OnClick="@(() => DeleteAsync(context.Item))"/>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
            <PagerContent>
                <MudDataGridPager T="ModpackAdminRowDto" PageSizeOptions="new[] { 25, 50, 100 }"/>
            </PagerContent>
        </MudDataGrid>
    }
</MudPaper>

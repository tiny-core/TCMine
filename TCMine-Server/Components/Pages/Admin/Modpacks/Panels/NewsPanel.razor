@namespace TCMine_Server.Components.Pages.Admin.Modpacks
@using TCMine_Domain.Entities

@* Aba "Novidades" do editor: newsletter por modpack em tabela (padrão das listas — MudDataGrid com
   busca + pager). Self-contained: carrega e persiste por conta própria. Ver NewsPanel.razor.cs. *@



<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudText Typo="Typo.body2" Color="Color.Secondary">
        Publicadas na página deste modpack.
    </MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add" OnClick="NewAsync">
        Nova novidade
    </MudButton>
</MudStack>

@if (_news is null)
{
    @* O BusyOverlay cobre o carregamento *@
}
else if (_news.Count == 0)
{
    <MudStack AlignItems="AlignItems.Center" Class="py-12">
        <MudIcon Icon="@Icons.Material.Filled.Newspaper" Size="Size.Large" Color="Color.Secondary"/>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Nenhuma novidade publicada para este modpack.
        </MudText>
    </MudStack>
}
else
{
    <MudDataGrid T="NewsEntity" Items="_news" Hover="true" Dense="true" Outlined="true"
                 FixedHeader="true" Height="50vh" Filterable="false" QuickFilter="Filter"
                 RowsPerPage="25">
        <ToolBarContent>
            <MudTextField @bind-Value="_search" Placeholder="Filtrar por título ou tag…"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true" Clearable="true" Class="mt-0" Margin="Margin.Dense"/>
        </ToolBarContent>
        <Columns>
            <TemplateColumn Title="Título" Sortable="true" SortBy="x => x.Title">
                <CellTemplate>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        @if (!string.IsNullOrWhiteSpace(context.Item.Tag))
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text">@context.Item.Tag</MudChip>
                        }
                        <div>
                            <MudText Typo="Typo.body2">@context.Item.Title</MudText>
                            @if (!string.IsNullOrWhiteSpace(context.Item.Summary))
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block text-truncate"
                                         Style="max-width:420px">@context.Item.Summary</MudText>
                            }
                        </div>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Status" Sortable="true" SortBy="x => x.IsPublished" CellStyle="text-align:center">
                <CellTemplate>
                    @if (context.Item.IsPublished)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">Publicado</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Rascunho</MudChip>
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Publicado em" Sortable="true" SortBy="x => x.PublishedAt">
                <CellTemplate>@context.Item.PublishedAt.ToString("dd/MM/yyyy")</CellTemplate>
            </TemplateColumn>
            <TemplateColumn Sortable="false" CellStyle="text-align:right">
                <CellTemplate>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                   OnClick="@(() => EditAsync(context.Item))"/>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                   OnClick="@(() => DeleteAsync(context.Item))"/>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="NewsEntity" PageSizeOptions="new[] { 25, 50, 100 }"/>
        </PagerContent>
    </MudDataGrid>
}

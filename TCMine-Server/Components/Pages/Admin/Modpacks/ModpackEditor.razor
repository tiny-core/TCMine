@page "/admin/modpacks/new"
@page "/admin/modpacks/{Id}"
@using Microsoft.AspNetCore.Authorization
@using TCMine_Domain.Modpack
@using TCMine_Server.Components.Pages.Admin.Modpacks.Panels
@layout AdminLayout
@attribute [Authorize(Roles = "Owner,Admin")]

@* Editor de modpack: orquestra as abas, cada uma num componente próprio (ver Panels/). O cabeçalho
   moderno concentra identidade + status + Guardar; o conteúdo vai para os painéis. *@

@if (_loading)
{
    <MudStack AlignItems="AlignItems.Center" Class="py-12">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary"/>
    </MudStack>
}
else
{
    @* ── Cabeçalho ──────────────────────────────────────────────────────────────────── *@
    <MudPaper Elevation="0" Outlined="true" Class="pa-4 mb-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween"
                  Wrap="Wrap.Wrap" Spacing="3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/admin/modpacks"
                               Variant="Variant.Outlined"/>
                <div>
                    <MudText Typo="Typo.h5">@(_isNew ? "Novo modpack" : _draft.Name)</MudText>
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="mt-1" Wrap="Wrap.Wrap">
                        @if (_draft.IsPublished)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled"
                                     Icon="@Icons.Material.Filled.Public">Publicado
                            </MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined"
                                     Icon="@Icons.Material.Filled.EditNote">Rascunho
                            </MudChip>
                        }
                        @if (!string.IsNullOrWhiteSpace(_draft.Minecraft))
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                                     Icon="@Icons.Material.Filled.SportsEsports">@_draft.Minecraft</MudChip>
                        }
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                                 Icon="@Icons.Material.Filled.Build">@ModLoaders.DisplayName(_draft.Loader) @_draft.LoaderVersion</MudChip>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                                 Icon="@Icons.Material.Filled.Extension">@_mods.Count mod(s)
                        </MudChip>
                    </MudStack>
                </div>
            </MudStack>

            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                @if (_saving && _saveTotal > 0)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@_saveStatus</MudText>
                }
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.Save" Disabled="_saving" OnClick="SaveAsync">
                    @(_saving ? "Guardando…" : "Guardar")
                </MudButton>
            </MudStack>
        </MudStack>

        @if (_saving && _saveTotal > 0)
        {
            <MudProgressLinear Color="Color.Primary" Class="mt-3" Rounded="true"
                               Value="@(_saveTotal == 0 ? 0 : 100.0 * _saveCurrent / _saveTotal)"/>
        }
    </MudPaper>

    @if (!_cfConfigured)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
            Token do CurseForge não configurado — busca e import indisponíveis.
            <MudLink Href="/admin/settings" Class="ml-1">Configurar</MudLink>
        </MudAlert>
    }

    @* ── Origem CF (modpack importado): versão + verificar/atualizar ──────────────────────── *@
    @if (_importSource is not null)
    {
        <MudAlert Severity="@(_importSource.UpdateAvailable ? Severity.Warning : Severity.Normal)"
                  Variant="Variant.Outlined" Class="mb-4" Icon="@Icons.Material.Filled.Cloud">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceAround"
                      Wrap="Wrap.Wrap" Spacing="2">
                <div>
                    <MudText Typo="Typo.body2">
                        Importado do CurseForge: <b>@_importSource.CurseProjectName</b>
                        @if (!string.IsNullOrWhiteSpace(_importSource.InstalledVersion))
                        {
                            <span class="ml-1">v(@_importSource.InstalledVersion)</span>
                        }
                    </MudText>
                    @if (_importSource.UpdateAvailable)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Warning">
                            Atualização disponível: @_importSource.LatestVersion
                        </MudText>
                    }
                    else if (_importSource.LastCheckedAt is not null)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Sem atualizações na última verificação.
                        </MudText>
                    }
                </div>
                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Text" Size="Size.Small" Disabled="!_cfConfigured"
                               StartIcon="@Icons.Material.Filled.Refresh" OnClick="CheckModpackUpdateAsync">
                        Verificar atualização
                    </MudButton>
                    @if (_importSource.UpdateAvailable)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.SystemUpdateAlt" OnClick="UpdateModpackAsync">
                            Atualizar para @_importSource.LatestVersion
                        </MudButton>
                    }
                </MudStack>
            </MudStack>
        </MudAlert>
    }

    @* ── Abas (cada conteúdo é um componente próprio) ──────────────────────────────── *@
    @* ActivePanelIndex controlado + OnPreviewInteraction: mostra o overlay antes do render pesado. *@
    <MudTabs @ref="_tabs" Elevation="0" Outlined="true" ApplyEffectsToContainer="true" TabPanelsClass="pa-4"
             Rounded="true" ActivePanelIndex="_activeTab" OnPreviewInteraction="OnTabPreview">

        <MudTabPanel Text="Detalhes" Icon="@Icons.Material.Filled.Info">
            <DetailsPanel Draft="_draft"/>
        </MudTabPanel>

        <MudTabPanel Text="@($"Mods ({_mods.Count})")" Icon="@Icons.Material.Filled.Extension">
            <ModsPanel Mods="_mods" CfConfigured="_cfConfigured"
                       OnSearchCf="SearchModsAsync" OnImport="ImportModpackAsync"
                       OnUploadJar="UploadJarAsync" OnRemove="RemoveMod"
                       OnCheckUpdates="CheckModUpdatesAsync"/>
        </MudTabPanel>

        <MudTabPanel Text="Overrides" Icon="@Icons.Material.Filled.Folder">
            @if (_isNew)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    Guarde o modpack primeiro para editar overrides.
                </MudAlert>
            }
            else
            {
                @if (_pendingOverrides is not null)
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-4">
                        Há overrides importados pendentes. Clique em <b>Guardar</b> para extraí-los e editá-los aqui.
                    </MudAlert>
                }

                @* Painel próprio (árvore lazy + Monaco) — recriado por @key a cada save p/ refletir o disco *@
                <OverridesPanel ModpackId="_draft.Id" @key="_overridesVersion"/>
            }
        </MudTabPanel>

        <MudTabPanel Text="Novidades" Icon="@Icons.Material.Filled.Newspaper">
            @if (_isNew)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    Guarde o modpack primeiro para publicar novidades.
                </MudAlert>
            }
            else
            {
                <NewsPanel ModpackId="_draft.Id" @key="_draft.Id"/>
            }
        </MudTabPanel>

        <MudTabPanel Text="@($"Servidores ({_draft.Servers.Count})")" Icon="@Icons.Material.Filled.Dns">
            <ServersPanel Servers="_draft.Servers"/>
        </MudTabPanel>
    </MudTabs>
}

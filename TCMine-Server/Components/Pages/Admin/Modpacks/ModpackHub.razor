@page "/admin/modpacks/{Id:guid}"
@using Microsoft.AspNetCore.Authorization
@using TCMine_Domain.Modpack
@layout AdminLayout
@attribute [Authorize(Roles = "Owner,Admin")]

@* Hub (overview) do modpack: resumo + cartões das áreas + as instâncias de servidor derivadas. *@

@if (_pack is not null)
{
    <MudPaper Elevation="0" Outlined="true" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween">
            <MudBreadcrumbs Items="_breadcrumbItems"/>
            <MudButton StartIcon="@Icons.Material.Filled.Tune"
                       Class="px-6"
                       OnClick="EditDetailsAsync">
                Detalhes
            </MudButton>
        </MudStack>
    </MudPaper>

    @* ── Cabeçalho ──────────────────────────────────────────────────────────────────── *@
    <MudPaper Elevation="0" Outlined="true" Class="pa-4 mb-4">
        <MudStack Justify="Justify.Center" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.h5">@_pack.Name</MudText>
            <MudDivider/>
            <MudStack Row="true">
                @if (_pack.IsPublished)
                {
                    <MudChip T="string" Size="Size.Small"
                             Color="Color.Success"
                             Variant="Variant.Filled"
                             Icon="@Icons.Material.Filled.Public">
                        Publicado
                    </MudChip>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small"
                             Color="Color.Default"
                             Variant="Variant.Outlined"
                             Icon="@Icons.Material.Filled.EditNote">
                        Rascunho
                    </MudChip>
                }
                <MudChip T="string" Size="Size.Small"
                         Variant="Variant.Text"
                         Icon="@Icons.Material.Filled.SportsEsports">
                    @_pack.Minecraft
                </MudChip>
                <MudChip T="string" Size="Size.Small"
                         Variant="Variant.Text"
                         Icon="@Icons.Material.Filled.Build">
                    @ModLoaders.DisplayName(_pack.Loader) @_pack.LoaderVersion
                </MudChip>
                @if (!string.IsNullOrWhiteSpace(_pack.CurseForgeUrl))
                {
                    <MudChip T="string" Href="@_pack.CurseForgeUrl" Target="_blank" Size="Size.Small"
                             Variant="Variant.Filled" Icon="@Icons.Material.Filled.OpenInNew"
                             Style="background:#F16436;color:#fff;">CurseForge</MudChip>
                }
            </MudStack>
        </MudStack>
    </MudPaper>

    @* ── Cartões das áreas de conteúdo ─────────────────────────────────────────────── *@
    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Outlined="true" Class="pa-4">
                <MudStack Justify="Justify.Center" AlignItems="AlignItems.Center">
                    <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Extension" Color="Color.Primary"/>
                        <MudText Typo="Typo.h6">@_pack.ModCount mod(s)</MudText>
                    </MudStack>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Mods do modpack (cliente e servidor).</MudText>
                    <MudDivider/>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true"
                               Href="@($"/admin/modpacks/{Id}/mods")">Gerenciar
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Outlined="true" Class="pa-4">
                <MudStack Justify="Justify.Center" AlignItems="AlignItems.Center">
                    <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Folder" Color="Color.Primary"/>
                        <MudText Typo="Typo.h6">Overrides</MudText>
                    </MudStack>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @(_pack.HasOverrides ? "Configs e arquivos extras." : "Sem overrides ainda.")
                    </MudText>
                    <MudDivider/>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true"
                               Href="@($"/admin/modpacks/{Id}/overrides")">Gerenciar
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Outlined="true" Class="pa-4">
                <MudStack Justify="Justify.Center" AlignItems="AlignItems.Center">
                    <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Newspaper" Color="Color.Primary"/>
                        <MudText Typo="Typo.h6">Novidades</MudText>
                    </MudStack>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Posts exibidos no launcher.</MudText>
                    <MudDivider/>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" OnClick="OpenNewsAsync">
                        Gerenciar
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Outlined="true" Class="pa-4">
                <MudStack Justify="Justify.Center" AlignItems="AlignItems.Center">
                    <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Lan" Color="Color.Primary"/>
                        <MudText Typo="Typo.h6">@_pack.ServerCount conexão(ões)</MudText>
                    </MudStack>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Servidores divulgados no launcher.</MudText>
                    <MudDivider/>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true"
                               OnClick="OpenConnectionsAsync">Gerenciar
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* ── Instâncias de servidor derivadas deste modpack ────────────────────────────── *@
    <MudPaper Elevation="0" Outlined="true" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween">
            <MudStack>
                <MudText Typo="Typo.h6">Servidores deste modpack</MudText>
                <MudDivider/>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Instâncias gerenciadas (containers) derivadas deste modpack.
                </MudText>
            </MudStack>
            <MudButton Variant="Variant.Text"
                       Color="Color.Primary"
                       Class="px-6"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="CreateInstanceAsync">Criar servidor
            </MudButton>
        </MudStack>
    </MudPaper>

    @if (_instances is null || _instances.Count == 0)
    {
        <MudPaper Elevation="0" Outlined="true" Class="pa-4">

            <MudStack AlignItems="AlignItems.Center" Class="py-8">
                <MudIcon Icon="@Icons.Material.Filled.Dns" Color="Color.Secondary" Size="Size.Large"/>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Nenhuma instância ainda. Crie um servidor a partir deste modpack.
                </MudText>
            </MudStack>
        </MudPaper>
    }
    else
    {
        <MudGrid>
            @foreach (var inst in _instances)
            {
                <MudItem xs="12" md="6">
                    <MudCard>
                        <MudCardHeader>
                            <CardHeaderAvatar>
                                <MudIcon Icon="@Icons.Material.Filled.Dns"/>
                            </CardHeaderAvatar>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle1">@inst.Name</MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <MudTooltip Text="Detalhe e console">
                                    <MudIconButton Icon="@Icons.Material.Filled.Terminal"
                                                   Color="Color.Primary"
                                                   OnClick="@(() => OpenInstance(inst))"/>
                                </MudTooltip>
                                <MudTooltip Text="Apagar servidor">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Color="Color.Error"
                                                   OnClick="@(() => DeleteInstanceAsync(inst))"/>
                                </MudTooltip>

                            </CardHeaderActions>
                        </MudCardHeader>
                        <MudDivider/>
                        <MudCardContent>
                            <MudStack Row="true" 
                                      AlignItems="AlignItems.Center" 
                                      Justify="Justify.Center"
                                      Wrap="Wrap.Wrap">
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                                         Icon="@Icons.Material.Filled.Sync"
                                         Color="@StatusColor(inst.Status)">
                                    @StatusLabel(inst.Status)
                                </MudChip>
                                <MudChip T="string" Size="Size.Small"
                                         Icon="@Icons.Material.Filled.Lan">
                                    porta @inst.Port
                                </MudChip>
                                @if (!inst.Provisioned)
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                             Color="Color.Warning"
                                             Icon="@Icons.Material.Filled.Build">
                                        Não provisionada
                                    </MudChip>
                                }
                                else if (inst.IsStale)
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                             Color="Color.Warning"
                                             Icon="@Icons.Material.Filled.Sync">
                                        Desatualizada
                                    </MudChip>
                                }
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
}

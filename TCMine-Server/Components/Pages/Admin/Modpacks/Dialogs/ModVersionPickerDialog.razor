@namespace TCMine_Server.Components.Pages.Admin.Modpacks.Dialogs
@using TCMine_Application.Contracts

@* Seletor de versão de um mod do CurseForge. Recebe os arquivos (já buscados lazy pelo editor) e
   devolve o escolhido ao clicar. Ver code-behind. *@

<MudDialog>
    <DialogContent>
        @if (Files.Count == 0)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">Nenhuma versão disponível.</MudText>
        }
        else
        {
            @* Scroll num <div> simples (como CurseForgeSearchDialog); a lista usa MudList/MudListItem —
               MudButton como linha de lista colapsava e não rolava. Clicar num item escolhe a versão. *@
            <div style="min-height:200px; max-height:55vh; overflow-y:auto;">
                <MudList T="long" Dense="true">
                    @foreach (var f in Files)
                    {
                        <MudListItem T="long" Value="f.Id" OnClick="@(() => Pick(f))">
                            <div>
                                <MudText Typo="Typo.body2">
                                    @(f.DisplayName ?? f.FileName)
                                    @if (f.Id == CurrentFileId)
                                    {
                                        <span style="opacity:.6"> · atual</span>
                                    }
                                </MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@f.FileName</MudText>
                            </div>
                        </MudListItem>
                    }
                </MudList>
            </div>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
    </DialogActions>
</MudDialog>

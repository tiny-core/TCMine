@page "/Error"
@layout MainLayout
@using Severity = MudBlazor.Severity

<ErrorScreen Code="500"
             Title="Ocorreu um erro"
             Message="Ocorreu um erro inesperado. Por favor, tente novamente ou contate um administrador."
             Icon="@Icons.Material.Filled.ErrorOutline"
             Color="Color.Error">

    @* Exibe o Request ID para facilitar o diagnóstico nos logs do servidor *@
    @if (ShowRequestId)
    {
        <MudAlert Severity="Severity.Warning" Dense="true" Variant="Variant.Outlined" Class="mt-2">
            Request ID: <code>@RequestId</code>
        </MudAlert>
    }

    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/"
               StartIcon="@Icons.Material.Filled.Home" Class="mt-2">
        Voltar para a Home
    </MudButton>
</ErrorScreen>
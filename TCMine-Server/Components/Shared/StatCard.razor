@* Card de estatística reutilizável: faixa de acento + ícone tingido + valor em destaque
   + rótulo e (opcional) subtítulo. Usado na grade de KPIs do Dashboard. *@

@* A var CSS --accent é lida pelo StatCard.razor.css para tingir faixa e ícone conforme a Color *@
<MudPaper Class="pa-4 align-content-center" MinHeight="190px" Elevation="0" Outlined="true"
          Style="@($"--accent: var(--mud-palette-{PaletteVar});")">

    <MudStack Justify="Justify.Center" AlignItems="AlignItems.Center" Row="true" Spacing="0">
        <MudIcon Icon="@Icon" Color="@Color" Title="@Title" Class="mr-5" Style="font-size: 2.8rem;"/>
        <MudStack Spacing="1">
            <MudText Typo="Typo.h4">@Value</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@Title</MudText>
        </MudStack>
    </MudStack>

    <MudDivider DividerType="DividerType.Middle" Class="my-2"/>

    <MudStack Justify="Justify.Center" Row="true" Spacing="0" Wrap="Wrap.Wrap">
        @ChildContent
    </MudStack>

</MudPaper>
<component name="ProjectRunConfigurationManager">
  <!-- Monta a imagem do TCMine-Server a partir do publish (build-image.ps1): publica no host e
       sobe via docker compose. O Dockerfile só copia ./publish — sem SDK/build dentro do container.
       Mesmo modelo da config de watch: Shell Script INLINE (powershell.exe) no terminal integrado —
       o modo "executar arquivo" exige interpretador absoluto e quebra ("Interpreter not found"). -->
  <configuration default="false" name="Build Docker Image" type="ShConfigurationType">
    <option name="SCRIPT_TEXT" value="Set-ExecutionPolicy -Scope Process Bypass -Force; ./build-image.ps1" />
    <option name="INDEPENDENT_SCRIPT_PATH" value="true" />
    <option name="SCRIPT_PATH" value="" />
    <option name="SCRIPT_OPTIONS" value="" />
    <option name="INDEPENDENT_SCRIPT_WORKING_DIRECTORY" value="true" />
    <option name="SCRIPT_WORKING_DIRECTORY" value="$PROJECT_DIR$" />
    <option name="INDEPENDENT_INTERPRETER_PATH" value="true" />
    <option name="INTERPRETER_PATH" value="powershell.exe" />
    <option name="INTERPRETER_OPTIONS" value="" />
    <option name="EXECUTE_IN_TERMINAL" value="true" />
    <option name="EXECUTE_SCRIPT_FILE" value="false" />
    <envs />
    <method v="2" />
  </configuration>
</component>

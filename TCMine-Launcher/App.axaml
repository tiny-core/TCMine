<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="TCMine_Launcher.App"
             xmlns:local="using:TCMine_Launcher"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://TCMine-Launcher/Themes/Styles/Text.axaml" />
        <StyleInclude Source="avares://TCMine-Launcher/Themes/Styles/Buttons.axaml" />
        <StyleInclude Source="avares://TCMine-Launcher/Themes/Styles/Cards.axaml" />
    </Application.Styles>
</Application>

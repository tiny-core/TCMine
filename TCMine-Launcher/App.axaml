<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="TCMine_Launcher.App"
             xmlns:local="using:TCMine_Launcher"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://TCMine-Launcher/Themes/Icons.axaml" />
                <ResourceInclude Source="avares://TCMine-Launcher/Themes/WindowChrome.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://TCMine-Launcher/Themes/Styles/Text.axaml" />
        <StyleInclude Source="avares://TCMine-Launcher/Themes/Styles/Buttons.axaml" />
        <StyleInclude Source="avares://TCMine-Launcher/Themes/Styles/Cards.axaml" />
        <StyleInclude Source="avares://TCMine-Launcher/Themes/Styles/Controls.axaml" />
    </Application.Styles>
</Application>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TCMine_Launcher.ViewModels"
             xmlns:conv="using:TCMine_Launcher.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="TCMine_Launcher.Views.PlaceholderPageView"
             x:DataType="vm:PlaceholderPageViewModel">

    <Panel Background="Transparent">
        <StackPanel Spacing="14" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="360">
            <Border Width="64" Height="64" CornerRadius="16" Background="{DynamicResource BgElevated}"
                    HorizontalAlignment="Center">
                <PathIcon Data="{Binding IconKey, Converter={x:Static conv:IconKeyConverter.Instance}}"
                          Width="28" Height="28" Foreground="{DynamicResource TextDim}"
                          HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="{Binding Title}" Classes="page-title" HorizontalAlignment="Center" />
            <TextBlock Text="{Binding Subtitle}" Classes="muted" TextAlignment="Center"
                       TextWrapping="Wrap" HorizontalAlignment="Center" />
        </StackPanel>
    </Panel>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="540"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:TCMine_Launcher.ViewModels"
             xmlns:conv="clr-namespace:TCMine_Launcher.Converters"
             x:Class="TCMine_Launcher.Views.ModpacksPageView"
             x:DataType="viewModels:ModpacksPageViewModel">

    <Grid RowDefinitions="Auto,*" Margin="28,24" Background="Transparent">

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Modpacks" Classes="page-title" />
                <TextBlock Text="Escolhe um modpack oficial para jogar" Classes="muted" Margin="0,3,0,0" />
            </StackPanel>
            <Button Grid.Column="1" Classes="outline-btn" Content="Atualizar"
                    Command="{Binding Refresh}" VerticalAlignment="Center" />
        </Grid>

        <Panel Grid.Row="1">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Modpacks}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:ModpackListItem">
                            <Border Classes="modpack-card" Margin="0,0,16,16">
                                <StackPanel>
                                    <!-- Banner com a tag OFICIAL -->
                                    <Border Height="72" CornerRadius="12,12,0,0" ClipToBounds="True">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                                <GradientStop Color="{DynamicResource AccentDeepColor}" Offset="0" />
                                                <GradientStop Color="{DynamicResource BgElevatedColor}" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border Classes="tag" Margin="14" VerticalAlignment="Center"
                                                HorizontalAlignment="Left" Background="#33000000">
                                            <TextBlock Text="OFICIAL" Foreground="White" />
                                        </Border>
                                    </Border>

                                    <StackPanel Margin="18,15,18,18">
                                        <TextBlock Text="{Binding Summary.Name}" Classes="card-title" />
                                        <TextBlock Text="{Binding Summary.Version}" Classes="faint" Margin="0,5,0,0" />

                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
                                            <Border Classes="badge" Background="{DynamicResource BgElevated}">
                                                <TextBlock Text="{Binding Summary.Minecraft}" FontSize="10.5"
                                                           Foreground="{DynamicResource TextSecondary}" />
                                            </Border>
                                            <Border Classes="badge" Background="{DynamicResource BgElevated}">
                                                <TextBlock Text="{Binding Summary.Loader}" FontSize="10.5"
                                                           Foreground="{DynamicResource TextSecondary}" />
                                            </Border>
                                            <Border Classes="badge" Background="{DynamicResource SuccessBg}"
                                                    IsVisible="{Binding Summary.ServerCount, Converter={x:Static conv:Converters.IntIsPositive}}">
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <Ellipse Width="6" Height="6" Fill="{DynamicResource Success}"
                                                             VerticalAlignment="Center" />
                                                    <TextBlock Text="Servidor" FontSize="10"
                                                               Foreground="{DynamicResource Success}"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <TextBlock Text="{Binding Summary.Description}"
                                                   Foreground="{DynamicResource TextMuted}" FontSize="12"
                                                   TextWrapping="Wrap" Height="36" Margin="0,10,0,0"
                                                   TextTrimming="CharacterEllipsis" />

                                        <Button Classes="play-btn" Height="38" Margin="0,14,0,0"
                                                HorizontalAlignment="Stretch" Content="{Binding ActionLabel}"
                                                Command="{Binding Open}" FontSize="12.5" FontWeight="Bold" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <StackPanel IsVisible="{Binding IsEmpty}" Spacing="8"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Nenhum modpack publicado ainda." Classes="muted" HorizontalAlignment="Center" />
            </StackPanel>

            <TextBlock Text="{Binding Error}" Foreground="{DynamicResource Danger}"
                       TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Center"
                       IsVisible="{Binding Error, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </Panel>
    </Grid>
</UserControl>
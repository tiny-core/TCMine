<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TCMine_Launcher.ViewModels"
             xmlns:models="using:TCMine_Domain.Launcher"
             xmlns:conv="using:TCMine_Launcher.Converters"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="540"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="TCMine_Launcher.Views.InstancesPageView"
             x:DataType="vm:InstancesPageViewModel">

    <Grid RowDefinitions="Auto,*" Margin="28,24">

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Instâncias" Classes="page-title" />
                <TextBlock Text="As tuas instâncias instaladas" Classes="muted" Margin="0,3,0,0" />
            </StackPanel>
            <Button Grid.Column="1" Classes="outline-btn" Content="Importar" Click="OnImport"
                    VerticalAlignment="Center" />
        </Grid>

        <Panel Grid.Row="1">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Shell.Installed}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:InstalledModpack">
                            <Border Classes="panel" Padding="16,14" Margin="0,0,0,12">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       VerticalAlignment="Center" />
                                            <!-- Badge de indisponibilidade (modpack/servidor removido no servidor) -->
                                            <Border Classes="badge warn" VerticalAlignment="Center"
                                                    IsVisible="{Binding HasAvailabilityWarning}"
                                                    ToolTip.Tip="{Binding AvailabilityMessage}">
                                                <TextBlock Text="{Binding AvailabilityMessage}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding VersionSummary}" Classes="faint" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                                VerticalAlignment="Center">
                                        <Button Classes="outline-btn" Content="RAM" Click="OnEditRam"
                                                ToolTip.Tip="Memória alocada a esta instância" />
                                        <Button Classes="outline-btn" Content="Shaders" Click="OnOpenShaders"
                                                ToolTip.Tip="Abrir a pasta de shaders" />
                                        <Button Classes="outline-btn" Content="Texturas" Click="OnOpenTextures"
                                                ToolTip.Tip="Abrir a pasta de resource packs (texturas)" />
                                        <Button Classes="outline-btn" Content="Exportar" Click="OnExport" />
                                        <Button Classes="outline-btn" Content="Eliminar" Click="OnDelete" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8"
                        IsVisible="{Binding Shell.Installed.Count, Converter={x:Static conv:Converters.IntIsZero}}">
                <TextBlock Text="Nenhuma instância instalada." Classes="muted" HorizontalAlignment="Center" />
                <TextBlock Text="Instala um modpack na aba Modpacks." Classes="faint" HorizontalAlignment="Center" />
            </StackPanel>
        </Panel>
    </Grid>
</UserControl>

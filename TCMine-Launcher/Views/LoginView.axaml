<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TCMine_Launcher.ViewModels"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="560"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="TCMine_Launcher.Views.LoginView"
             x:DataType="vm:LoginViewModel">

    <Panel Background="{DynamicResource BgPageBrush}">

        <!-- Cartão de login centrado -->
        <Border Classes="card">
            <StackPanel HorizontalAlignment="Stretch">

                <Image Source="/Assets/icon.png" Width="58" Height="58"
                       HorizontalAlignment="Center" />
                <TextBlock Text="TCMine Launcher" FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,10,0,0" />
                <TextBlock Text="Entra para jogar os modpacks oficiais"
                           Classes="muted" HorizontalAlignment="Center" Margin="0,5,0,0" />

                <Separator Classes="divider" Margin="0,26" />

                <!-- Botão Microsoft -->
                <Button Classes="ms-btn" Command="{Binding SignIn}">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <!-- Logótipo Microsoft (4 quadrados) -->
                        <Grid Width="18" Height="18" RowDefinitions="*,*" ColumnDefinitions="*,*"
                              VerticalAlignment="Center">
                            <Rectangle Grid.Row="0" Grid.Column="0" Fill="#F25022" Margin="0,0,1,1" />
                            <Rectangle Grid.Row="0" Grid.Column="1" Fill="#7FBA00" Margin="1,0,0,1" />
                            <Rectangle Grid.Row="1" Grid.Column="0" Fill="#00A4EF" Margin="0,1,1,0" />
                            <Rectangle Grid.Row="1" Grid.Column="1" Fill="#FFB900" Margin="1,1,0,0" />
                        </Grid>
                        <TextBlock Text="Entrar com a Microsoft" FontSize="13.5"
                                   FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Estado: a autenticar -->
                <StackPanel Spacing="10" Margin="0,18,0,0" IsVisible="{Binding Busy}">
                    <ProgressBar IsIndeterminate="True" />
                    <TextBlock Text="{Binding Status}" Classes="muted" FontSize="12.5"
                               HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
                </StackPanel>

                <!-- Estado: erro -->
                <TextBlock Text="{Binding Error}"
                           IsVisible="{Binding Error, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                           Foreground="{DynamicResource ErrorBrush}" FontSize="11.5"
                           TextWrapping="Wrap" TextAlignment="Center" Margin="0,16,0,0" />

                <TextBlock Text="O login abre no teu navegador. Volta aqui depois de autorizares."
                           Classes="faint" FontSize="10.5" TextWrapping="Wrap"
                           TextAlignment="Center" Margin="0,22,0,0" />
            </StackPanel>
        </Border>
    </Panel>
</UserControl>

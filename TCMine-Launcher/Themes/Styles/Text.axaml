<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===================================================================
         TEXTO — classes tipográficas. Cor sempre dos tokens de ColorTokens
         (via AvaloniaTheme → DynamicResource), nunca hexes literais.
         =================================================================== -->

    <Style Selector="TextBlock.page-title">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="TextBlock.card-title">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="TextBlock.muted">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style Selector="TextBlock.faint">
        <Setter Property="Foreground" Value="{DynamicResource TextDisabledBrush}" />
        <Setter Property="FontSize" Value="11" />
    </Style>
</Styles>

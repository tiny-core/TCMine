<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Controlos — spinner e barras de progresso (estrutura do backup; cores dos tokens). -->

    <!-- ── Spinner (anel a girar) ──────────────────────────────────── -->
    <Style Selector="Ellipse.spinner">
        <Setter Property="Width" Value="30" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Stroke" Value="{DynamicResource Accent}" />
        <Setter Property="StrokeThickness" Value="3" />
        <Setter Property="StrokeDashArray" Value="8,23" />
        <Setter Property="StrokeLineCap" Value="Round" />
        <Setter Property="RenderTransformOrigin" Value="50%,50%" />
        <Style.Animations>
            <Animation Duration="0:0:0.85" IterationCount="Infinite">
                <KeyFrame Cue="0%">
                    <Setter Property="RotateTransform.Angle" Value="0" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="RotateTransform.Angle" Value="360" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- ── Progresso fino (barra de estado) ────────────────────────── -->
    <Style Selector="ProgressBar.status-progress">
        <Setter Property="Background" Value="{DynamicResource BgHover}" />
        <Setter Property="Foreground" Value="{DynamicResource Accent}" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="Height" Value="5" />
        <Setter Property="MinWidth" Value="160" />
    </Style>
</Styles>

<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===================================================================
         CARTÕES, PAINÉIS E SUPERFÍCIES. Cores dos tokens (ColorTokens via
         AvaloniaTheme → DynamicResource).
         =================================================================== -->

    <!-- ── Cartão central (login) ──────────────────────────────────── -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{DynamicResource BgSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="40,38" />
        <Setter Property="Width" Value="400" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ── Cartão de modpack ───────────────────────────────────────── -->
    <Style Selector="Border.modpack-card">
        <Setter Property="Background" Value="{DynamicResource BgSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Width" Value="290" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.modpack-card:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource Primary500Brush}" />
    </Style>

    <!-- ── Tag (chip outline da marca; ex.: "OFICIAL") ─────────────── -->
    <Style Selector="Border.tag">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource Primary500Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="5" />
        <Setter Property="Padding" Value="8,3" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
    <Style Selector="Border.tag > TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Primary500Brush}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LetterSpacing" Value="1" />
    </Style>

    <!-- ── Badge de estado (forma; cor via tokens semânticos) ──────── -->
    <Style Selector="Border.badge">
        <Setter Property="CornerRadius" Value="5" />
        <Setter Property="Padding" Value="7,3" />
    </Style>

    <!-- ── Avatar do jogador (círculo laranja) ─────────────────────── -->
    <Style Selector="Border.avatar">
        <Setter Property="CornerRadius" Value="1000" />
        <Setter Property="Background" Value="{DynamicResource Primary500Brush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.avatar > TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextOnPrimaryBrush}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ── Divisória horizontal ────────────────────────────────────── -->
    <Style Selector="Separator.divider">
        <Setter Property="Height" Value="1" />
        <Setter Property="MinHeight" Value="1" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Background" Value="{DynamicResource BorderBrush}" />
    </Style>

    <!-- ── Overlay de ocupado (loading) ────────────────────────────── -->
    <Style Selector="Border.busy-overlay">
        <Setter Property="Background" Value="{DynamicResource BgPageBrush}" />
        <Setter Property="Opacity" Value="0.78" />
    </Style>
</Styles>

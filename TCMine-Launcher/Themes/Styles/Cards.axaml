<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Cartões, painéis e superfícies (estrutura do backup; cores dos tokens via DynamicResource). -->

    <!-- ── Cartão central (login) ──────────────────────────────────── -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{DynamicResource BgPanel}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="40,38" />
        <Setter Property="Width" Value="400" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ── Painel genérico ─────────────────────────────────────────── -->
    <Style Selector="Border.panel">
        <Setter Property="Background" Value="{DynamicResource BgPanel}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="22" />
    </Style>

    <!-- ── Cartão de modpack ───────────────────────────────────────── -->
    <Style Selector="Border.modpack-card">
        <Setter Property="Background" Value="{DynamicResource BgPanel}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Width" Value="290" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.modpack-card:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
    </Style>

    <!-- ── Tag (chip da marca; ex.: "OFICIAL") ─────────────────────── -->
    <Style Selector="Border.tag">
        <Setter Property="Background" Value="{DynamicResource AccentBg}" />
        <Setter Property="CornerRadius" Value="5" />
        <Setter Property="Padding" Value="8,3" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
    <Style Selector="Border.tag > TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Accent}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LetterSpacing" Value="1" />
    </Style>

    <!-- ── Badge de estado (forma; cor via tokens) ─────────────────── -->
    <Style Selector="Border.badge">
        <Setter Property="CornerRadius" Value="5" />
        <Setter Property="Padding" Value="7,3" />
    </Style>

    <!-- ── Avatar do jogador (círculo laranja) ─────────────────────── -->
    <Style Selector="Border.avatar">
        <Setter Property="CornerRadius" Value="1000" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="{DynamicResource AccentColor}" Offset="0" />
                    <GradientStop Color="{DynamicResource AccentDeepColor}" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>
    <Style Selector="Border.avatar > TextBlock">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ── Divisória ───────────────────────────────────────────────── -->
    <Style Selector="Separator.divider">
        <Setter Property="Height" Value="1" />
        <Setter Property="MinHeight" Value="1" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Background" Value="{DynamicResource BorderDivider}" />
    </Style>

    <!-- ── Overlay de ocupado ──────────────────────────────────────── -->
    <Style Selector="Border.busy-overlay">
        <Setter Property="Background" Value="{DynamicResource BgWindow}" />
        <Setter Property="Opacity" Value="0.78" />
    </Style>
</Styles>
